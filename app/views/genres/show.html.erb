<h1><%= @genre.name %></h1>

<% if @genre_movies.present? %>
  <h3>Movies</h3>
  <div class="favorite-movies">
    <% @genre_movies.each do |movie| %>
      <%= link_to image_tag(movie.image_file_name), movie %>
    <% end %>
  </div>
<% end %>

<% if current_user_admin? %>
  <section class="admin">
    <div class="actions">
      <%= link_to "Edit", edit_genre_path(@genre), class: "button edit" %>
      <%= link_to "Delete", (@genre), class: "button delete",
          data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
    </div>
  </section>
<% end %>