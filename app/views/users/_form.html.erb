<%= form_with(model: user) do|u| %>
    <%= render "shared/errors", object:user %>

    <%= u.label :name %>
    <%= u.text_field :name, autofocus: true %>

    <%= u.label :username %>
    <%= u.text_field :username, placeholder: "Alphanumeric characters only!" %>

    <%= u.label :email %>
    <%= u.email_field :email %>

    <%= u.label :password %>
    <%= u.password_field :password %>

    <%= u.label :password_confirmation, "Confirm password" %>
    <%= u.password_field :password_confirmation %>   


    <% if user.new_record? %>
        <%= u.submit "Create Account" %>
    <% else %>
        <%= u.submit "Update Account" %>
    <% end %>

<% end %>